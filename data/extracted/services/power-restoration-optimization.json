    "body_html": "<div class=\"entry-content\">\n<div data-elementor-id=\"18287\" data-elementor-type=\"wp-page\">\n<section data-settings='{\"background_background\":\"classic\",\"stretch_section\":\"section-stretched\"}'>\n<div>\n<div>\n<div>\n<section>\n<div>\n<div>\n<div>\n<div data-widget_type=\"heading.default\">\n<div>\n<h2>Your Partner in <br/>Power Restoration &amp; Optimization</h2> </div>\n</div>\n</div>\n</div>\n</div>\n</section>\n</div>\n</div>\n</div>\n</section>\n<section data-settings='{\"stretch_section\":\"section-stretched\",\"background_background\":\"gradient\"}'>\n<div>\n<div>\n<div>\n<section>\n<div>\n<div>\n<div>\n<div data-widget_type=\"image.default\">\n<div>\n<img alt=\"\" decoding=\"async\" fetchpriority=\"high\" height=\"1024\" sizes=\"(max-width: 1024px) 100vw, 1024px\" src=\"https://carelabz.com/wp-content/uploads/2024/04/carelabsit_Craft_a_high-quality_image_illustrating_a_team_of__c312a39e-bc93-4a57-b53b-983011930c8b_0.png\" srcset=\"https://carelabz.com/wp-content/uploads/2024/04/carelabsit_Craft_a_high-quality_image_illustrating_a_team_of__c312a39e-bc93-4a57-b53b-983011930c8b_0.png 1024w, https://carelabz.com/wp-content/uploads/2024/04/carelabsit_Craft_a_high-quality_image_illustrating_a_team_of__c312a39e-bc93-4a57-b53b-983011930c8b_0-150x150.png 150w, https://carelabz.com/wp-content/uploads/2024/04/carelabsit_Craft_a_high-quality_image_illustrating_a_team_of__c312a39e-bc93-4a57-b53b-983011930c8b_0-768x768.png 768w, https://carelabz.com/wp-content/uploads/2024/04/carelabsit_Craft_a_high-quality_image_illustrating_a_team_of__c312a39e-bc93-4a57-b53b-983011930c8b_0-320x320.png 320w, https://carelabz.com/wp-content/uploads/2024/04/carelabsit_Craft_a_high-quality_image_illustrating_a_team_of__c312a39e-bc93-4a57-b53b-983011930c8b_0-480x480.png 480w, https://carelabz.com/wp-content/uploads/2024/04/carelabsit_Craft_a_high-quality_image_illustrating_a_team_of__c312a39e-bc93-4a57-b53b-983011930c8b_0-800x800.png 800w, https://carelabz.com/wp-content/uploads/2024/04/carelabsit_Craft_a_high-quality_image_illustrating_a_team_of__c312a39e-bc93-4a57-b53b-983011930c8b_0-45x45.png 45w\" width=\"1024\"> </img></div>\n</div>\n</div>\n</div>\n<div>\n<div>\n<div data-widget_type=\"heading.default\">\n<div>\n<h2>Key Focus Areas for Care Labs in Power Restoration</h2> </div>\n</div>\n<div data-widget_type=\"text-editor.default\">\n<div>\n<p><strong>Safety First:</strong> We prioritize your well-being. Our recovery work follows the strictest safety standards to protect you.</p><p><br><strong>Damage Experts:</strong> We assess flood-specific electrical damage, finding hidden issues to speed up restoration.<br/><br/><strong>Official Compliance:</strong> We work with authorities and your teams to ensure repairs meet all codes for fast reconnection.<br/><br/><strong>No Power? No Problem:</strong> We handle submerged equipment – DON’T touch it yourself. Call us for a safe inspection.</br></p> </div>\n</div>\n</div>\n</div>\n</div>\n</section>\n</div>\n</div>\n</div>\n</section>\n<section data-settings='{\"stretch_section\":\"section-stretched\",\"background_background\":\"classic\"}'>\n<div>\n<div>\n<div>\n<section>\n<div>\n<div>\n<div>\n<div data-widget_type=\"shortcode.default\">\n<div>\n<div><iframe data-cf-modified-a92bfd31fa097d24b71eb9a0-=\"\" data-load-mode=\"1\" data-src=\"https://forms.clickup.com/25582210/f/rcpm2-66216/68D7E2FVBGGDNHXTOG\" height=\"100%\" onwheel=\"if (!window.__cfRLUnblockHandlers) return false; \" src=\"data:image/gif;base64,R0lGODlhAQABAAAAACH5BAEKAAEALAAAAAABAAEAAAICTAEAOw==\" width=\"100%\"></iframe></div>\n</div>\n</div>\n</div>\n</div>\n</div>\n</section>\n</div>\n</div>\n</div>\n</section>\n</div>\n</div>",
