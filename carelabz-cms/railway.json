{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "buildCommand": "NODE_OPTIONS='--max-old-space-size=1024' npm run build",
    "watchPatterns": ["src/**"]
  },
  "deploy": {
    "startCommand": "npm run start",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE"
  }
}
